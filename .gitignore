# Root .gitignore additions
/models/*
!/models/.gitkeep
!/models/.gitignore

/data/*
!/data/.gitkeep
!/data/.gitignore

# Sensitive files (always exclude)
.env
*.key
*.secret
# Root .gitignore additions
/models/*
!/models/.gitkeep
!/models/.gitignore

/data/*
!/data/.gitkeep
!/data/.gitignore

# Sensitive files (always exclude)
.env
*.key
*.secret
data/memory/*.json
__pycache__/
*.pyc
*.pyo
.pytest_cache/
