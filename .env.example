# Exchange credentials — required for live trading, optional for dry-run
EXCHANGE_API_KEY=your_binance_api_key_here
EXCHANGE_SECRET_KEY=your_binance_secret_key_here

# Set EXCHANGE_SANDBOX=true to use Binance testnet (paper trading with real API flow)
EXCHANGE_SANDBOX=false

# Set to "true" to simulate trades without placing real orders (recommended for testing)
DRY_RUN=true

# Telegram alerts — optional
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# QuantMind research pipeline — required only if running research_updater.py
OPENAI_API_KEY=your_openai_api_key_here

# Emergency manual override — NEVER set in production
# CIRCUIT_BREAKER_OVERRIDE=true
